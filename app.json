{
  "expo": {
    "name": "aha-register",
    "slug": "aha-register",
    "scheme": "aharegister",
    "version": "0.5.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#1E2D3D",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E2D3D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tedeholdings.aharegister",
      "buildNumber": "4",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "aha! Register uses the camera to photograph and document objects with tamper-evident SHA-256 hashing.",
        "NSPhotoLibraryUsageDescription": "aha! Register accesses photos to import existing images of objects for documentation.",
        "NSLocationWhenInUseUsageDescription": "aha! Register records GPS coordinates as part of the tamper-evident capture record.",
        "NSMicrophoneUsageDescription": "aha! Register uses the microphone for video narration during object documentation."
      }
    },
    "android": {
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#1E2D3D",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "package": "com.tedeholdings.aharegister"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.5"
          }
        }
      ],
      [
        "expo-sqlite",
        {
          "useSQLCipher": true
        }
      ],
      "expo-sharing",
      "expo-updates",
      [
        "@sentry/react-native/expo",
        {
          "uploadSourceMaps": false
        }
      ],
      "expo-secure-store",
      "react-native-document-scanner-plugin",
      "rn-mlkit-ocr",
      "expo-video",
      "expo-localization"
    ],
    "runtimeVersion": "0.5.1",
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/bec4d444-c862-47d2-b326-37eaa5a4519e",
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "extra": {
      "eas": {
        "projectId": "bec4d444-c862-47d2-b326-37eaa5a4519e"
      },
      "versioning": "version and runtimeVersion must stay in sync; bump them together on each meaningful release (see docs/VERSIONING.md)."
    },
    "owner": "aha-register"
  }
}
